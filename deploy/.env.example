# Authorize.net Credentials
AUTHORIZE_API_LOGIN_ID=your-api-login-id
AUTHORIZE_TRANSACTION_KEY=your-transaction-key

# Application Configuration
# ⚠️ IMPORTANT: For production, use public domain/IP, NOT localhost
# APP_BASE_URL is used for payment return URL after Authorize.net checkout
# ALLOWED_ORIGINS is for CORS - must match where users access the form
#
# Production example:
# APP_BASE_URL=https://www.pondmobile.com
# ALLOWED_ORIGINS=https://www.pondmobile.com,https://pondmobile.com
#
# Development (localhost only):
APP_BASE_URL=http://localhost:5001
ALLOWED_ORIGINS=http://localhost:5001,http://127.0.0.1:5001

# Environment
FLASK_ENV=production
DOCKER_ENV=true
